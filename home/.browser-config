envfile="$HOME/.context.env"
[ -f "$envfile" ] && . "$envfile"

envfile="$HOME/.browser.env"
[ -f "$envfile" ] && . "$envfile"

case "$1" in
  pro)
    profile=$BROWSER_WORK
    shift
    ;;
  perso)
    profile=$BROWSER_PERSONAL
    shift
    ;;
  *)
    case "$CONTEXT" in
      work)
        profile=$BROWSER_WORK
        ;;
      home)
        profile=$BROWSER_PERSONAL
        ;;
      *)
        profile="Default"
    esac
esac

mode=$(gsettings get org.gnome.desktop.interface color-scheme | sed -E "s/'prefer-(\w+)'/\1/")
color=$(cat -s "$HOME/.chrome_colors/$mode")

