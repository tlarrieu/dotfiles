export SHLVL=1
export LUA_PATH="$HOME/lua/?.lua;;"
export PATH="$HOME/bin:$PATH"
export PATH="$HOME/scripts:$PATH"
export PATH="$HOME/apps:$PATH"

# shellcheck disable=SC1090
[ -f ~/.xprofile.local ] && . ~/.xprofile.local

if [ "$(date +%H)" -gt 18 ] || [ "$(date +%H)" -lt 7 ]; then
  ~/git/dotfiles/coloriage/coloriage set dark
else
  ~/git/dotfiles/coloriage/coloriage set light
fi

pgrep unclutter || unclutter -root -idle 2 2>/dev/null &
pgrep picom || picom 2>/dev/null &

setxkbmap -option ctrl:nocaps -model pc105 -layout "fr" -variant "bepo"
xcape -e 'Control_L=Escape'

xset s off -dpms # disable screen saving / blanking
xset r rate 210 35 # make key repeat faster
